        "# 4\n",
        "# Phoneme category dictionary\n",
        "phoneme_classes = {\n",
        "    \"Vowel\": [\"AA\",\"AE\",\"AH\",\"AO\",\"AW\",\"AY\",\"EH\",\"ER\",\"EY\",\"IH\",\"IY\",\"OW\",\"OY\",\"UH\",\"UW\"],\n",
        "    \"Plosive\": [\"P\",\"B\",\"T\",\"D\",\"K\",\"G\"],\n",
        "    \"Fricative\": [\"F\",\"V\",\"S\",\"Z\",\"SH\",\"ZH\",\"TH\",\"DH\",\"HH\"],\n",
        "    \"Affricate\": [\"CH\",\"JH\"],\n",
        "    \"Semivowel\": [\"Y\",\"W\",\"R\",\"L\"],\n",
        "    \"Nasal\": [\"M\",\"N\",\"NG\"]\n",
        "}\n",
        "\n",
        "def get_phoneme_category(phoneme):\n",
        "    for category, plist in phoneme_classes.items():\n",
        "        if phoneme in plist:\n",
        "            return category\n",
        "    return \"Unknown\"\n",
        "\n",
        "print(\"Phoneme Classification:\\n\")\n",
        "\n",
        "for i, (phoneme, start_time, end_time) in enumerate(phoneme_intervals):\n",
        "    category = get_phoneme_category(phoneme)\n",
        "    print(\n",
        "        f\"Segment {i+1}: \"\n",
        "        f\"Phoneme = {phoneme:<3} | \"\n",
        "        f\"Category = {category:<10} | \"\n",
        "        f\"Time = {start_time:.3f}s – {end_time:.3f}s\"\n",
        "    )\n"
